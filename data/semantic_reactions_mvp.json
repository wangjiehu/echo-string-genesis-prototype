      "triggerEvents": ["OnFieldOverlap", "OnOppositeFieldInjectedIntoSameSlot", "OnTagInjected"],
      "validTargetTypes": ["FieldPillar", "Enemy", "Boss", "Mechanism", "Debris", "Stone"],
