        "Semantic.Structure.Fragile"
      ],
      "triggerEvents": ["OnTagInjected", "OnHeavyAttackImpact", "OnEnvironmentalImpact"],
      "validTargetTypes": ["Enemy", "Boss", "Door", "Stone", "Mechanism"],
      "effect": {
        "statusDurationSeconds": 5.0,
        "nextHeavyHitDamageMultiplier": 2.5,
        "nextHeavyHitStaggerMultiplier": 2.0,
        "breakThresholdBonus": 35,
        "consumedOnHeavyHit": true
      },
      "vfxId": "VFX_Reaction_FractureWindow",
      "sfxId": "SFX_Reaction_FractureWindow",
      "playerReadableCause": "冻结让结构变脆，脆弱让裂纹扩散。",
      "designUse": "把解谜破坏逻辑带入战斗，避免冻结成为纯控制。"
    },
    {
      "reactionId": "Reaction.FieldPulse",
      "displayName": "力场震荡",
      "requiredTags": [
