      "effect": {
        "damage": 12,
        "damageType": "ThermalPressure",
        "knockbackForce": 650,
        "blindDurationSeconds": 2.5,
        "createsCoverCloudSeconds": 4.0,
        "removesTagsAfterTrigger": ["Semantic.Medium.Wet"],
        "shortensTagDuration": {
          "Semantic.Temperature.Overheated": 0.4
        }
      },
      "vfxId": "VFX_Reaction_SteamBurst",
      "sfxId": "SFX_Reaction_SteamBurst",
      "playerReadableCause": "过热遇到潮湿，水汽瞬间膨胀。",
      "designUse": "教学第一个组合反应，同时提供战斗遮蔽和击退。"
    },
    {
      "reactionId": "Reaction.FractureWindow",
      "displayName": "破裂窗口",
      "requiredTags": [
