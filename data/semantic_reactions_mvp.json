        "pullForce": 700,
        "pushForce": 1100,
        "damage": 8,
        "damageType": "Force",
        "staggerMultiplier": 1.4,
        "reactionCooldownSeconds": 8.0
      },
      "vfxId": "VFX_Reaction_FieldPulse",
      "sfxId": "SFX_Reaction_FieldPulse",
      "playerReadableCause": "吸引和排斥相互覆盖，力场先坍缩再弹开。",
      "designUse": "用于群体控场、碎片移动和Boss第三层护文反制；同槽相反力场写入时也可触发，但必须防止连续触发。"
    }
